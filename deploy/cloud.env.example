COMPOSE_PROJECT_NAME=alphadesk-cloud
ALPHADESK_VERSION=local
ALPHADESK_HTTP_BIND=127.0.0.1
ALPHADESK_PORT=18080
ALPHADESK_DATA_ROOT=./data

# Shared secret used by Hermes Agent when calling /api/agent/*.
ALPHADESK_AGENT_TOKEN=replace-with-long-random-token

# Model provider used to generate HTML reports.
ALPHADESK_MODEL_PROVIDER_NAME=Cloud Model
ALPHADESK_MODEL_BASE_URL=https://api.deepseek.com
ALPHADESK_MODEL_NAME=deepseek-chat
ALPHADESK_MODEL_PROTOCOL=openai_chat_completions
ALPHADESK_MODEL_API_KEY=replace-with-model-api-key
ALPHADESK_MODEL_EXTRA_BODY={}

# WeRSS admin credentials for the rachelos/we-mp-rss sidecar.
WERSS_USERNAME=admin
WERSS_PASSWORD=replace-with-werss-admin-password
WERSS_SECRET_KEY=replace-with-werss-secret-key

# ZSXQ MCP source.
ALPHADESK_ZSXQ_MCP_URL=https://mcp.zsxq.com/topic/mcp?api_key=replace-with-zsxq-mcp-key
ALPHADESK_ZSXQ_PAGE_LIMIT=10
ALPHADESK_ZSXQ_MAX_PAGES=10

# IMA OpenAPI source.
ALPHADESK_IMA_CLIENT_ID=replace-with-ima-client-id
ALPHADESK_IMA_API_KEY=replace-with-ima-api-key
ALPHADESK_IMA_KNOWLEDGE_BASE_IDS=
